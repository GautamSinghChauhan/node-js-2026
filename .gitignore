###################################
# Node.js Production .gitignore
###################################

# Dependencies
node_modules/
jspm_packages/
web_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output
*.lcov

# Build output
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/

# Environment files (VERY IMPORTANT)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# TypeScript
*.tsbuildinfo

# npm cache
.npm

# Optional REPL history
.node_repl_history

# Temporary files
tmp/
temp/

# Debug
*.tgz

###################################
# Security
###################################
*.pem
*.key
*.crt

###################################
# Testing
###################################
coverage/
jest.config.js.snap

###################################
# Docker (optional)
###################################
docker-compose.override.yml